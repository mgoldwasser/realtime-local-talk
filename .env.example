# --- AWS ---
# Used by boto3 (Bedrock, Polly). Either set these or rely on `aws configure`
# / SSO / instance role. The plan uses us-east-1 for the widest Bedrock model
# selection; switch to your home region as needed.
AWS_REGION=us-east-1
AWS_PROFILE=default
# Or, instead of a profile:
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=...

# --- OpenAI ---
# Used for Tier-2b GPT-5 escalation and the web_search tool.
OPENAI_API_KEY=

# --- Alex runtime config ---
# Activation: wakeword | ptt | both
ALEX_ACTIVATION=ptt
# TTS backend: polly | kokoro
ALEX_TTS=polly
# Polly voice (any Generative-engine voice in your region)
ALEX_POLLY_VOICE=Ruth
# LLM tier defaults (cross-region inference profile IDs work too)
ALEX_LLM_HAIKU=us.anthropic.claude-haiku-4-5-20251001-v1:0
ALEX_LLM_SONNET=us.anthropic.claude-sonnet-4-5-20250929-v1:0
# Audio devices (leave blank for system default; set exact CoreAudio names later)
ALEX_INPUT_DEVICE=
ALEX_OUTPUT_DEVICE=
# Set to true ONLY if your input device has hardware AEC (Jabra Speak2 75,
# Poly Sync 60, etc.). Without it the self-mute strategy must stay on to
# prevent echo loops. See docs/aec-status.md.
ALEX_HARDWARE_AEC_PRESENT=false

# Wake-word tuning. 0.5 default; lower if your voice scores below threshold
# in the `wake score=` logs. Try 0.3 with the placeholder before training.
ALEX_WAKEWORD_THRESHOLD=0.5
ALEX_WAKEWORD_LISTEN_SECS=10.0
# Path to a custom .onnx model. Leave blank to use the bundled "alexa" model.
ALEX_WAKEWORD_MODEL_PATH=

# --- LISTEN mode (--mode listen) ---
ALEX_LISTEN_TRIGGERS=alex,hey alex,ask alex
ALEX_LISTEN_BUFFER_MINUTES=5.0
# Follow-up window: grace period right after Alex finishes speaking, and how
# many seconds each VAD user-start event adds. Set both very low to require
# trigger phrase on every turn; set initial to 0 to disable follow-up.
ALEX_LISTEN_FOLLOW_UP_INITIAL_SECS=10.0
ALEX_LISTEN_FOLLOW_UP_EXTEND_SECS=6.0
